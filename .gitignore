# Python caches and local build/distribution metadata
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Repository-local runtimes and solver outputs are intentionally versioned:
# - `.venv/`, `libs/`, and `interpreter/` stay in Git so an expert user can
#   inspect or repair a broken bootstrap without starting from zero.
# - `exports/` and OpenVSP/VSPAERO output files stay in Git so the latest
#   reference artifacts remain visible even on a machine that cannot rerun them.

# Alternative local env names and bootstrap scratch space
.conda/
.tmp/
venv/
env/

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE / editor state
.vscode/
.idea/
*.swp
*.swo

# Operating system noise
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log