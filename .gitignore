# Repository-local runtimes and solver outputs are intentionally versioned:
# - `exports/` and OpenVSP/VSPAERO output files stay in Git so the latest
#   reference artifacts remain visible even on a machine that cannot rerun them.

# Alternative local env names and bootstrap scratch space
.conda/
.tmp/
venv/
env/
interpreter/

# IMPORTANT: .venv is now excluded from Git because it is heavy (~1GB).
# The project will automatically create .venv on first run via run_project.bat setup.
.venv/

# Ambiente virtuale creato da uv
.venv/
__pycache__/
*.py[cod]

# Cartelle create da uv e dall'ambiente virtuale
.uv_bin/


# Cartelle inutili che avevi prima
interpreter/

